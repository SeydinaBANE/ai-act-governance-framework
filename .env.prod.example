# ============================================================
# AI Act Governance Framework — Production Environment
# Copier en .env.prod et NE JAMAIS COMMITER
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=aiact_prod
POSTGRES_PASSWORD=CHANGER_MOT_DE_PASSE_FORT_ICI
POSTGRES_DB=aiact_governance_prod
DATABASE_URL=postgresql+asyncpg://aiact_prod:CHANGER_MOT_DE_PASSE_FORT_ICI@postgres:5432/aiact_governance_prod  # pragma: allowlist secret

# ---- JWT — générer avec: python -c "import secrets; print(secrets.token_hex(32))" ----
SECRET_KEY=CHANGER_CLE_JWT_32_CHARS_HEX_ICI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- OpenRouter ----
OPENROUTER_API_KEY=sk-or-v1-VOTRE_CLE_ICI
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Presidio ----
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3001
PRESIDIO_CONFIDENCE_THRESHOLD=0.85

# ---- App ----
ENVIRONMENT=production
LOG_LEVEL=WARNING
ALLOWED_ORIGINS=["https://aiact.votre-domaine.fr"]

# ---- Upload ----
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# ---- Frontend ----
NEXT_PUBLIC_API_URL=https://api.aiact.votre-domaine.fr/api/v1
