# ============================================================
# AI Act Governance Framework — Environment Variables
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITER .env
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=aiact
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=aiact_governance
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aiact:change_me_in_production@postgres:5432/aiact_governance

# ---- JWT Auth ----
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_with_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- OpenRouter (LLM) ----
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Presidio ----
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3001
PRESIDIO_CONFIDENCE_THRESHOLD=0.85

# ---- App ----
ENVIRONMENT=development
# production | staging | development
LOG_LEVEL=INFO
# Format JSON obligatoire pour pydantic-settings v2 (liste)
ALLOWED_ORIGINS=["http://localhost:3000"]

# ---- Upload ----
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# ---- Tests (uniquement en dev) ----
# Rempli automatiquement par testcontainers — ne pas modifier
TEST_DATABASE_URL=
